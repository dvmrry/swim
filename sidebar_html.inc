"<!DOCTYPE html>"
"<html><head><meta charset='utf-8'>"
"<style>"
"* { margin: 0; padding: 0; box-sizing: border-box; }"
"body {"
"  background: %BG%;"
"  color: %FG%;"
"  font-family: 'SF Mono', 'Menlo', 'Monaco', monospace;"
"  font-size: 13px;"
"  display: flex;"
"  flex-direction: column;"
"  height: 100vh;"
"  overflow: hidden;"
"}"
".header {"
"  padding: 8px 12px 6px;"
"  border-bottom: 1px solid %STATUS_BG%;"
"  display: flex;"
"  align-items: center;"
"  gap: 6px;"
"  flex-shrink: 0;"
"}"
".header-dot {"
"  width: 8px; height: 8px;"
"  border-radius: 50%;"
"  background: %ACCENT%;"
"}"
".header-title {"
"  color: %FG_DIM%;"
"  font-size: 11px;"
"  font-weight: 600;"
"  letter-spacing: 0.5px;"
"  text-transform: uppercase;"
"}"
".messages {"
"  flex: 1;"
"  overflow-y: auto;"
"  padding: 12px;"
"  display: flex;"
"  flex-direction: column;"
"  gap: 12px;"
"}"
".messages::-webkit-scrollbar { width: 4px; }"
".messages::-webkit-scrollbar-track { background: transparent; }"
".messages::-webkit-scrollbar-thumb { background: %FG_DIM%; border-radius: 2px; }"
".msg {"
"  line-height: 1.5;"
"  white-space: pre-wrap;"
"  word-wrap: break-word;"
"}"
".msg-user {"
"  color: %FG%;"
"}"
".msg-user::before {"
"  content: '> ';"
"  color: %ACCENT%;"
"  font-weight: bold;"
"}"
".msg-ai {"
"  color: %FG_DIM_BRIGHT%;"
"  padding-left: 4px;"
"}"
".msg-ai code {"
"  background: %STATUS_BG%;"
"  padding: 1px 4px;"
"  border-radius: 3px;"
"  font-size: 12px;"
"}"
".msg-ai pre {"
"  background: %STATUS_BG%;"
"  padding: 8px;"
"  border-radius: 4px;"
"  margin: 4px 0;"
"  overflow-x: auto;"
"  font-size: 12px;"
"}"
".msg-ai pre code {"
"  background: none;"
"  padding: 0;"
"}"
".msg-system {"
"  color: %ACCENT%;"
"  font-size: 11px;"
"  font-style: italic;"
"}"
".thinking {"
"  color: %FG_DIM%;"
"  font-size: 12px;"
"}"
".thinking::after {"
"  content: '';"
"  animation: dots 1.5s steps(4, end) infinite;"
"}"
"@keyframes dots {"
"  0%  { content: ''; }"
"  25% { content: '.'; }"
"  50% { content: '..'; }"
"  75% { content: '...'; }"
"}"
".empty-state {"
"  flex: 1;"
"  display: flex;"
"  flex-direction: column;"
"  align-items: center;"
"  justify-content: center;"
"  color: %FG_DIM%;"
"  gap: 8px;"
"  padding: 20px;"
"  text-align: center;"
"}"
".empty-state-title {"
"  font-size: 14px;"
"  color: %FG_DIM_BRIGHT%;"
"}"
".empty-state-hint {"
"  font-size: 11px;"
"  line-height: 1.6;"
"}"
".input-area {"
"  padding: 8px 12px;"
"  border-top: 1px solid %STATUS_BG%;"
"  flex-shrink: 0;"
"}"
".input-row {"
"  display: flex;"
"  align-items: flex-end;"
"  gap: 4px;"
"}"
".input-prompt {"
"  color: %ACCENT%;"
"  font-weight: bold;"
"  padding-bottom: 2px;"
"  flex-shrink: 0;"
"}"
"#input {"
"  flex: 1;"
"  background: transparent;"
"  border: none;"
"  color: %FG%;"
"  font-family: inherit;"
"  font-size: 13px;"
"  outline: none;"
"  resize: none;"
"  line-height: 1.5;"
"  max-height: 120px;"
"  overflow-y: auto;"
"  padding: 0;"
"}"
"#input::placeholder { color: %FG_DIM%; }"
"</style>"
"</head><body>"
"<div class='header'>"
"  <div class='header-dot'></div>"
"  <span class='header-title'>swim ai</span>"
"</div>"
"<div class='messages' id='messages'>"
"  <div class='empty-state'>"
"    <div class='empty-state-title'>AI Companion</div>"
"    <div class='empty-state-hint'>"
"      Ask about this page, get summaries,<br>"
"      fill forms, or learn workflows.<br><br>"
"      <span style='color:%FG_DIM%'>:ai &lt;prompt&gt;</span>"
"    </div>"
"  </div>"
"</div>"
"<div class='input-area'>"
"  <div class='input-row'>"
"    <span class='input-prompt'>&gt;</span>"
"    <textarea id='input' rows='1' placeholder='Ask anything...'></textarea>"
"  </div>"
"</div>"
"<script>"
"var messages = document.getElementById('messages');"
"var input = document.getElementById('input');"
"var promptHistory = [];"
"var historyIndex = -1;"
"var emptyState = document.querySelector('.empty-state');"
""
"function escapeHtml(s) {"
"  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');"
"}"
""
"function renderMarkdown(text) {"
"  var html = escapeHtml(text);"
"  html = html.replace(/```([\\s\\S]*?)```/g, '<pre><code>$1</code></pre>');"
"  html = html.replace(/`([^`]+)`/g, '<code>$1</code>');"
"  html = html.replace(/\\*\\*([^*]+)\\*\\*/g, '<strong>$1</strong>');"
"  html = html.replace(/^### (.+)$/gm, '<strong style=\"color:%FG%\">$1</strong>');"
"  html = html.replace(/^## (.+)$/gm, '<strong style=\"color:%FG%;font-size:14px\">$1</strong>');"
"  html = html.replace(/^# (.+)$/gm, '<strong style=\"color:%FG%;font-size:15px\">$1</strong>');"
"  html = html.replace(/^- (.+)$/gm, '  &bull; $1');"
"  return html;"
"}"
""
"function addMessage(role, text) {"
"  if (emptyState) { emptyState.remove(); emptyState = null; }"
"  var div = document.createElement('div');"
"  div.className = 'msg msg-' + role;"
"  if (role === 'ai') {"
"    div.innerHTML = renderMarkdown(text);"
"  } else {"
"    div.textContent = text;"
"  }"
"  messages.appendChild(div);"
"  messages.scrollTop = messages.scrollHeight;"
"  return div;"
"}"
""
"function showThinking() {"
"  if (emptyState) { emptyState.remove(); emptyState = null; }"
"  var div = document.createElement('div');"
"  div.className = 'msg thinking';"
"  div.id = 'thinking';"
"  div.textContent = 'thinking';"
"  messages.appendChild(div);"
"  messages.scrollTop = messages.scrollHeight;"
"}"
""
"function hideThinking() {"
"  var el = document.getElementById('thinking');"
"  if (el) el.remove();"
"}"
""
"input.addEventListener('keydown', function(e) {"
"  if (e.key === 'Enter' && !e.shiftKey) {"
"    e.preventDefault();"
"    var text = input.value.trim();"
"    if (!text) return;"
"    promptHistory.push(text);"
"    historyIndex = promptHistory.length;"
"    addMessage('user', text);"
"    input.value = '';"
"    input.style.height = 'auto';"
"    showThinking();"
"    window.webkit.messageHandlers.swim.postMessage("
"      {type:'sidebar-prompt', text:text}"
"    );"
"  } else if (e.key === 'ArrowUp' && input.value === '') {"
"    if (historyIndex > 0) {"
"      historyIndex--;"
"      input.value = promptHistory[historyIndex];"
"    }"
"  } else if (e.key === 'Escape') {"
"    window.webkit.messageHandlers.swim.postMessage({type:'sidebar-escape'});"
"  }"
"});"
""
"input.addEventListener('input', function() {"
"  this.style.height = 'auto';"
"  this.style.height = Math.min(this.scrollHeight, 120) + 'px';"
"});"
""
"input.addEventListener('focus', function() {"
"  window.webkit.messageHandlers.swim.postMessage({type:'focus',focused:true});"
"});"
""
"input.addEventListener('blur', function() {"
"  window.webkit.messageHandlers.swim.postMessage({type:'focus',focused:false});"
"});"
""
"function receiveResponse(text) {"
"  hideThinking();"
"  addMessage('ai', text);"
"}"
""
"function receiveSystem(text) {"
"  hideThinking();"
"  addMessage('system', text);"
"}"
""
"function focusInput() {"
"  input.focus();"
"}"
"</script>"
"</body></html>"
